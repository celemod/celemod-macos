{
  "identifier": "default",
  "description": "Default capabilities for CeleMod",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "dialog:default",
    "shell:allow-open",
    "os:default",
    "fs:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-center",
    "core:event:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*.weg.fan" },
        { "url": "https://*.0x0a.de" },
        { "url": "https://*.gamebanana.com" },
        { "url": "https://*.myqcloud.com" },
        { "url": "https://*.github.com" },
        { "url": "https://*.githubusercontent.com" }
      ]
    }
  ]
}
